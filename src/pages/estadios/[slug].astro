---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/config/site";
import { stadiums, getStadiumBySlug } from "@/data/stadiums";
import { fixtures, localTime } from "@/utils/fixtures";
import type { GetStaticPaths } from "astro";

export const getStaticPaths: GetStaticPaths = () => {
  return stadiums.map((s) => ({
    params: { slug: s.slug },
    props: { stadium: s },
  }));
};

const { stadium } = Astro.props;

const venueMatches = fixtures
  .filter((f) => f.venue.toLowerCase().includes(stadium.name.toLowerCase().split(" ")[0]) ||
                 f.venue === stadium.name)
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const breadcrumbs = [
  { name: "Inicio", item: site.url },
  { name: "Estadios", item: `${site.url}/estadios` },
  { name: stadium.name, item: `${site.url}/estadios/${stadium.slug}` },
];

const faqs = [
  {
    q: `¿Cuántos partidos se juegan en el ${stadium.name}?`,
    a: `El ${stadium.name} alberga ${venueMatches.length} partido(s) del Mundial 2026.`,
  },
  {
    q: `¿Cuál es la capacidad del ${stadium.name}?`,
    a: `El ${stadium.name} tiene capacidad para ${stadium.capacity.toLocaleString("es-AR")} espectadores.`,
  },
  {
    q: `¿Dónde está el ${stadium.name}?`,
    a: `El ${stadium.name} se encuentra en ${stadium.city}, ${stadium.country}.`,
  },
];
---

<BaseLayout
  title={`${stadium.name} — Mundial 2026: Partidos, Capacidad y Ubicación`}
  description={`Toda la información del ${stadium.name} para el Mundial 2026: partidos programados, capacidad de ${stadium.capacity.toLocaleString("es-AR")} espectadores, ubicación en ${stadium.city}.`}
  canonical={`${site.url}/estadios/${stadium.slug}`}
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <h1>{stadium.name} — Mundial 2026</h1>
  <p>
    El <strong>{stadium.name}</strong> en {stadium.city}, {stadium.country} es una de las sedes del
    <strong>Mundial 2026</strong>. Capacidad: {stadium.capacity.toLocaleString("es-AR")} espectadores.
  </p>

  <table style="margin-bottom:1rem">
    <tbody>
      <tr><td><strong>Ciudad</strong></td><td>{stadium.city}, {stadium.country}</td></tr>
      <tr><td><strong>Capacidad</strong></td><td>{stadium.capacity.toLocaleString("es-AR")} espectadores</td></tr>
      <tr><td><strong>Superficie</strong></td><td>{stadium.surface}</td></tr>
      <tr><td><strong>Inaugurado</strong></td><td>{stadium.built}</td></tr>
      <tr><td><strong>Partidos WC 2026</strong></td><td>{venueMatches.length}</td></tr>
    </tbody>
  </table>

  <h2>Datos del {stadium.name}</h2>
  <ul style="padding-left:1.25rem;line-height:2">
    {stadium.facts.map((fact) => <li>{fact}</li>)}
  </ul>

  <h2>Partidos del Mundial 2026 en el {stadium.name}</h2>
  {venueMatches.length === 0 ? (
    <p>Los partidos en este estadio se actualizarán cuando se confirme el calendario completo.</p>
  ) : (
    <table>
      <thead>
        <tr>
          <th>Partido</th>
          <th>Fase</th>
          <th>Fecha</th>
          <th>ARG/URU</th>
          <th>COL/PER</th>
          <th>CDMX</th>
        </tr>
      </thead>
      <tbody>
        {venueMatches.map((m) => {
          const d = new Date(m.date);
          const dateStr = d.toLocaleDateString("es-AR", { day: "numeric", month: "short", timeZone: "UTC" });
          return (
            <tr>
              <td><a href={`/${m.slug}`}>{m.teamA} vs {m.teamB}</a></td>
              <td style="font-size:.85rem">{m.group ? `Grupo ${m.group}` : (m.stage ?? "")}</td>
              <td style="white-space:nowrap;font-size:.85rem">{dateStr}</td>
              <td>{localTime(m.date, -3)}</td>
              <td>{localTime(m.date, -5)}</td>
              <td>{localTime(m.date, -6)}</td>
            </tr>
          );
        })}
      </tbody>
    </table>
  )}

  <h2>Preguntas Frecuentes — {stadium.name}</h2>
  {faqs.map(({ q, a }) => (
    <div style="margin-bottom:1rem">
      <h3>{q}</h3>
      <p>{a}</p>
    </div>
  ))}

  <p style="margin-top:1.5rem">
    ← <a href="/calendario">Calendario completo</a> ·
    <a href={`/ciudades/${stadium.citySlug}`}>Ciudad: {stadium.city}</a>
  </p>
</BaseLayout>
