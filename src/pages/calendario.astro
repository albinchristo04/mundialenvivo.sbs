---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/config/site";
import { groupFixtures, multiTzBlock, formatDateEs, localTime } from "@/utils/fixtures";

const matches = groupFixtures().sort(
  (a, b) => new Date(a.date).getTime() - new Date(b.date).getTime()
);

const groups = [...new Set(matches.map((m) => m.group))].sort() as string[];

const breadcrumbs = [
  { name: "Inicio", item: site.url },
  { name: "Calendario Mundial 2026", item: `${site.url}/calendario` },
];

const faqs = [
  {
    q: "¿Cuántos partidos tiene el Mundial 2026?",
    a: "El Mundial 2026 tiene 104 partidos en total: 72 de fase de grupos (12 grupos × 6 partidos), 32 de dieciseisavos, 16 de octavos, 8 de cuartos, 4 de semifinales, 1 tercer puesto y 1 final.",
  },
  {
    q: "¿Cuándo son los partidos de la fase de grupos del Mundial 2026?",
    a: "La fase de grupos del Mundial 2026 se desarrolla del 11 de junio al 27 de junio de 2026. Cada grupo juega 3 fechas con 6 partidos.",
  },
];
---

<BaseLayout
  title="Calendario Mundial 2026: Horarios y Canales de Todos los Partidos — Fase de Grupos"
  description="Calendario completo del Mundial 2026 con horarios por país (Argentina, Colombia, México, Perú, Chile) y dónde ver cada partido en el canal oficial de tu país."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <h1>Calendario Mundial 2026 — Horarios y Canales por Grupo</h1>
  <p>
    Todos los partidos del <strong>Mundial 2026</strong> con horarios en Argentina/Uruguay, Colombia/Perú/Ecuador y México.
    Hacé clic en cada partido para ver los canales oficiales de transmisión por país.
  </p>

  <p style="font-size:.875rem;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:6px;padding:.6rem 1rem;margin:.5rem 0 1rem">
    ⚽ Para ver en qué canal transmiten en tu país, hacé clic en el partido o visitá la
    <a href="/">guía de canales por país</a>.
  </p>

  {groups.map((g) => (
    <section>
      <h2><a href={`/grupo-${g.toLowerCase()}`}>Grupo {g}</a></h2>
      <table>
        <thead>
          <tr>
            <th>Partido</th>
            <th>Fecha</th>
            <th>ARG/URU</th>
            <th>COL/PER/ECU</th>
            <th>CDMX</th>
            <th>Sede</th>
          </tr>
        </thead>
        <tbody>
          {matches
            .filter((m) => m.group === g)
            .map((m) => {
              const arg  = localTime(m.date, -3);
              const col  = localTime(m.date, -5);
              const cdmx = localTime(m.date, -6);
              const d = new Date(m.date);
              const dateStr = d.toLocaleDateString("es-AR", { day: "numeric", month: "short", timeZone: "UTC" });
              return (
                <tr>
                  <td><a href={`/${m.slug}`}>{m.teamA} vs {m.teamB}</a></td>
                  <td style="white-space:nowrap">{dateStr}</td>
                  <td>{arg}</td>
                  <td>{col}</td>
                  <td>{cdmx}</td>
                  <td style="font-size:.8rem;color:#555">{m.city}</td>
                </tr>
              );
            })}
        </tbody>
      </table>
      <p style="font-size:.8rem;text-align:right;margin-top:-.25rem">
        <a href={`/grupo-${g.toLowerCase()}`}>Ver Grupo {g} completo →</a>
      </p>
    </section>
  ))}

  <h2>Preguntas Frecuentes — Calendario Mundial 2026</h2>
  {faqs.map(({ q, a }) => (
    <div style="margin-bottom:1rem">
      <h3>{q}</h3>
      <p>{a}</p>
    </div>
  ))}

  <p style="margin-top:1.5rem">
    ← <a href="/">Inicio</a> ·
    <a href="/partidos-hoy">Partidos de hoy</a> ·
    <a href="/tabla-posiciones">Tabla de posiciones</a> ·
    <a href="/cuadro-mundial-2026">Cuadro del torneo</a>
  </p>
</BaseLayout>
