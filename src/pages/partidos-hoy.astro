---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/config/site";
import { todaysFixtures, upcomingFixtures, multiTzBlock, formatDateEs } from "@/utils/fixtures";

const today = todaysFixtures();
const upcoming = upcomingFixtures(6);

const breadcrumbs = [
  { name: "Inicio", item: site.url },
  { name: "Partidos de Hoy", item: `${site.url}/partidos-hoy` },
];

const faqs = [
  {
    q: "¿Qué partidos del Mundial 2026 hay hoy?",
    a: today.length > 0
      ? `Hoy hay ${today.length} partido(s) del Mundial 2026: ${today.map(f => `${f.teamA} vs ${f.teamB}`).join(", ")}.`
      : "Hoy no hay partidos del Mundial 2026 programados. Consultá el calendario para los próximos partidos.",
  },
  {
    q: "¿A qué hora son los partidos del Mundial hoy?",
    a: "Los horarios de hoy se muestran en esta página con las conversiones para Argentina/Uruguay, Colombia/Perú/Ecuador y México.",
  },
];

const dateStr = new Date().toLocaleDateString("es-AR", {
  weekday: "long",
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "America/Argentina/Buenos_Aires",
});
---

<BaseLayout
  title={`Partidos de Hoy — Mundial 2026 en Vivo | ${site.brand}`}
  description="Ver los partidos del Mundial 2026 de hoy: horarios por país (Argentina, Colombia, México, Perú) y canales oficiales de transmisión en vivo."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <h1>Partidos del Mundial 2026 Hoy</h1>
  <p style="color:#555;font-size:.9rem">{dateStr}</p>

  {today.length === 0 ? (
    <div style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:1.5rem;margin:1rem 0;text-align:center">
      <p style="font-size:1.1rem;font-weight:600;margin-bottom:.5rem">No hay partidos hoy</p>
      <p>Consultá los próximos partidos del Mundial 2026 abajo o el <a href="/calendario">calendario completo</a>.</p>
    </div>
  ) : (
    today.map((f) => (
      <div class="match-card">
        <div class="teams"><a href={`/${f.slug}`}>{f.teamA} vs {f.teamB}</a></div>
        <div class="meta">{formatDateEs(f.date)} · {f.venue}, {f.city}</div>
        <div class="tz-block">{multiTzBlock(f.date)}</div>
        <a href={`/${f.slug}`} class="cta" style="margin-top:.5rem;display:inline-block">
          Ver canales oficiales para este partido →
        </a>
      </div>
    ))
  )}

  {today.length === 0 && upcoming.length > 0 && (
    <>
      <h2>Próximos Partidos del Mundial 2026</h2>
      {upcoming.map((f) => (
        <div class="match-card">
          <div class="teams"><a href={`/${f.slug}`}>{f.teamA} vs {f.teamB}</a></div>
          <div class="meta">{formatDateEs(f.date)} · {f.venue}, {f.city}</div>
          <div class="tz-block">{multiTzBlock(f.date)}</div>
          <a href={`/${f.slug}`} style="font-size:.9rem">¿Dónde ver? Canales oficiales →</a>
        </div>
      ))}
    </>
  )}

  <h2>Preguntas Frecuentes</h2>
  {faqs.map(({ q, a }) => (
    <div style="margin-bottom:1rem">
      <h3>{q}</h3>
      <p>{a}</p>
    </div>
  ))}

  <p style="margin-top:1.5rem">
    ← <a href="/">Inicio</a> ·
    <a href="/calendario">Calendario completo</a> ·
    <a href="/tabla-posiciones">Tabla de posiciones</a>
  </p>
</BaseLayout>
