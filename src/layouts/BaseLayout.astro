---
import { site } from "@/config/site";
import SchemaOrg from "@/components/SchemaOrg.astro";
import PromoBanner from "@/components/PromoBanner.astro";

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  keywords?: string;
  breadcrumbs?: { name: string; item?: string }[];
  faqs?: { q: string; a: string }[];
  match?: {
    teamA: string;
    teamB: string;
    date: string;
    venue: string;
    city: string;
    slug: string;
    countryCode?: string;
  };
  article?: {
    title: string;
    description: string;
    datePublished: string;
    author: string;
    url: string;
  };
  promoBanner?: boolean;
  promoBannerLabel?: string;
  promoBannerCountry?: string;
  noindex?: boolean;
}

const {
  title,
  description = site.description,
  canonical = Astro.url.href,
  ogImage = `${site.url}/og.png`,
  keywords = site.defaultKeywords,
  breadcrumbs,
  faqs,
  match,
  article,
  promoBanner = true,
  promoBannerLabel,
  promoBannerCountry,
  noindex = false,
} = Astro.props;

const lastModified = new Date().toISOString();
const fullTitle = title.includes(site.brand) ? title : `${title} | ${site.brand}`;
---

<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonical} />

    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1"} />
    <meta name="bingbot" content="index, follow" />
    <meta name="googlebot" content="index, follow" />

    <meta http-equiv="content-language" content={site.lang} />
    <meta name="language" content="Spanish" />
    <meta name="geo.region" content="AR" />
    <meta name="geo.placename" content="Argentina" />
    <meta name="author" content={site.brand} />
    <meta name="publisher" content={site.brand} />
    <meta name="revisit-after" content="1 day" />
    <meta http-equiv="last-modified" content={lastModified} />

    <link rel="alternate" hreflang="es" href={canonical} />
    <link rel="alternate" hreflang="es-ar" href={canonical} />
    <link rel="alternate" hreflang="es-419" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <meta property="og:type" content={article ? "article" : "website"} />
    <meta property="og:site_name" content={site.brand} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={site.locale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <SchemaOrg breadcrumbs={breadcrumbs} faqs={faqs} match={match} article={article} />

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { font-family: system-ui, -apple-system, sans-serif; font-size: 16px; color: #111; background: #fff; }
      body { max-width: 960px; margin: 0 auto; padding: 0 1rem 3rem; }
      a { color: #0057b7; }
      a:hover { color: #003d80; }
      header { padding: 1.25rem 0 1rem; border-bottom: 2px solid #e5e7eb; margin-bottom: 1.5rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: .5rem; }
      header .logo { font-size: 1.25rem; font-weight: 800; color: #111; text-decoration: none; }
      nav { display: flex; flex-wrap: wrap; gap: .25rem; }
      nav a { padding: .25rem .5rem; font-size: .875rem; text-decoration: none; color: #555; border-radius: 4px; }
      nav a:hover { color: #0057b7; background: #f3f4f6; }
      h1 { font-size: 1.75rem; line-height: 1.25; margin-bottom: .75rem; }
      h2 { font-size: 1.25rem; margin: 1.5rem 0 .5rem; }
      h3 { font-size: 1.05rem; margin: 1.25rem 0 .4rem; }
      p { line-height: 1.65; margin-bottom: .75rem; }
      .cta { display: inline-block; background: #15803d; color: #fff !important; padding: .6rem 1.4rem; border-radius: 6px; font-weight: 700; text-decoration: none; font-size: 1rem; margin: .5rem 0; }
      .cta:hover { background: #166534; }
      .match-card { border: 1px solid #e5e7eb; border-radius: 8px; padding: 1rem; margin-bottom: 1rem; }
      .match-card .teams { font-size: 1.15rem; font-weight: 700; margin-bottom: .25rem; }
      .match-card .meta { font-size: .875rem; color: #555; }
      .tz-block { background: #f3f4f6; padding: .75rem 1rem; border-radius: 6px; font-size: .9rem; margin: .75rem 0; line-height: 1.8; }
      table { width: 100%; border-collapse: collapse; font-size: .9rem; margin: 1rem 0; }
      th { text-align: left; padding: .5rem .75rem; background: #f3f4f6; font-size: .8rem; text-transform: uppercase; letter-spacing: .04em; }
      td { padding: .5rem .75rem; border-top: 1px solid #e5e7eb; }
      .tag { display: inline-block; background: #e0f2fe; color: #0369a1; border-radius: 999px; font-size: .75rem; padding: .1rem .5rem; }
      footer { margin-top: 3rem; border-top: 1px solid #e5e7eb; padding-top: 1.5rem; font-size: .8rem; color: #777; }
      footer .follow-title { font-weight: 700; color: #444; margin-bottom: .25rem; }
      footer .follow-links { margin-bottom: 1rem; }
      footer .follow-links a { color: #0057b7; }
      footer .internal-links { display: flex; flex-wrap: wrap; gap: .5rem; margin-bottom: 1rem; }
      footer .internal-links a { background: #f3f4f6; color: #555; border-radius: 4px; padding: .25rem .6rem; text-decoration: none; font-size: .8rem; }
      footer .internal-links a:hover { background: #e5e7eb; }
      @media (max-width: 600px) { h1 { font-size: 1.35rem; } }
    </style>
  </head>
  <body>
    {promoBanner && <PromoBanner matchLabel={promoBannerLabel} countryName={promoBannerCountry} />}

    <header>
      <a class="logo" href="/">⚽ {site.brand}</a>
      <nav>
        <a href="/calendario">Calendario</a>
        <a href="/partidos-hoy">Hoy</a>
        <a href="/tabla-posiciones">Tabla</a>
        <a href="/cuadro-mundial-2026">Cuadro</a>
        <a href="/noticias">Noticias</a>
        <a href="/faq">FAQ</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="internal-links">
        <a href="/argentina">🇦🇷 Argentina</a>
        <a href="/colombia">🇨🇴 Colombia</a>
        <a href="/mexico">🇲🇽 México</a>
        <a href="/peru">🇵🇪 Perú</a>
        <a href="/chile">🇨🇱 Chile</a>
        <a href="/venezuela">🇻🇪 Venezuela</a>
        <a href="/ecuador">🇪🇨 Ecuador</a>
        <a href="/uruguay">🇺🇾 Uruguay</a>
        <a href="/guatemala">🇬🇹 Guatemala</a>
        <a href="/bolivia">🇧🇴 Bolivia</a>
        <a href="/grupo-a">Grupo A</a>
        <a href="/grupo-b">Grupo B</a>
        <a href="/calendario">Calendario</a>
        <a href="/tabla-posiciones">Tabla</a>
        <a href="/cuadro-mundial-2026">Cuadro</a>
        <a href="/noticias">Noticias</a>
      </div>
      <p class="follow-title">Seguir las cuentas oficiales del Mundial 2026</p>
      <p class="follow-links">
        {site.officialAccounts.map((acc, i) => (
          <>
            {i > 0 && <span aria-hidden="true"> · </span>}
            <a href={acc.url} rel="noopener" target="_blank">{acc.name}</a>
          </>
        ))}
      </p>
      <p>© 2026 {site.brand} · <a href="/faq">Preguntas frecuentes</a> · <a href="/noticias">Noticias</a></p>
      <p style="margin-top:.5rem">Ver <a href={site.fifaUrl} rel="noopener" target="_blank">información oficial FIFA</a>. {site.brand} no está afiliado a la FIFA.</p>
    </footer>
  </body>
</html>
