---
import { getBroadcastersForCountry } from "@/utils/fixtures";
import { site } from "@/config/site";

export interface Props {
  countryCode: string;
  countryName: string;
}

const { countryCode, countryName } = Astro.props;
const broadcasters = getBroadcastersForCountry(countryCode);

const accessLabels: Record<string, string> = {
  "tv-free": "TV abierta",
  "tv-cable": "TV paga / cable",
  "streaming": "Streaming (suscripción)",
  "streaming-free": "Streaming gratuito",
  "info": "Información oficial",
};
---

<div class="broadcaster-list">
  <h3>Canales oficiales — {countryName}</h3>
  <ul>
    {broadcasters.map((b) => (
      <li>
        <a href={b.url} target="_blank" rel="noopener">
          <strong>{b.name}</strong>
        </a>
        {b.access && accessLabels[b.access] && (
          <span class="access-tag">{accessLabels[b.access]}</span>
        )}
      </li>
    ))}
    <li class="fifa-ref">
      <a href={site.fifaWatchUrl} target="_blank" rel="noopener">
        FIFA — Información oficial de transmisiones
      </a>
      <span class="access-tag">Referencia oficial</span>
    </li>
  </ul>
</div>

<style>
  .broadcaster-list {
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 8px;
    padding: 1rem 1.25rem;
    margin: 1rem 0;
  }
  .broadcaster-list h3 {
    font-size: .95rem;
    color: #166534;
    margin: 0 0 .5rem;
    text-transform: uppercase;
    letter-spacing: .04em;
  }
  .broadcaster-list ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: .4rem;
  }
  .broadcaster-list li {
    display: flex;
    align-items: center;
    gap: .5rem;
    flex-wrap: wrap;
  }
  .broadcaster-list a {
    color: #15803d;
  }
  .broadcaster-list a:hover {
    color: #14532d;
  }
  .access-tag {
    font-size: .75rem;
    background: #dcfce7;
    color: #166534;
    border-radius: 999px;
    padding: .1rem .5rem;
  }
  .fifa-ref {
    border-top: 1px solid #bbf7d0;
    padding-top: .4rem;
    margin-top: .25rem;
  }
</style>
