---
import { site } from "@/config/site";
import { getBroadcastersForCountry } from "@/utils/fixtures";

export interface Props {
  extra?: object[];
  breadcrumbs?: { name: string; item?: string }[];
  faqs?: { q: string; a: string }[];
  match?: {
    teamA: string;
    teamB: string;
    date: string;
    venue: string;
    city: string;
    slug: string;
    countryCode?: string;
  };
  article?: {
    title: string;
    description: string;
    datePublished: string;
    author: string;
    url: string;
  };
}

const { extra = [], breadcrumbs, faqs, match, article } = Astro.props;

const sameAs = [
  site.social.instagram && `https://www.instagram.com/${site.social.instagram}`,
  site.social.facebook && `https://www.facebook.com/${site.social.facebook}`,
  site.social.x && `https://x.com/${site.social.x}`,
  site.social.youtube && `https://www.youtube.com/@${site.social.youtube}`,
].filter(Boolean);

const graphs: object[] = [
  {
    "@type": "Organization",
    "@id": `${site.url}/#org`,
    name: site.brand,
    url: `${site.url}/`,
    logo: `${site.url}/favicon.svg`,
    description: site.description,
    ...(sameAs.length > 0 ? { sameAs } : {}),
  },
  {
    "@type": "WebSite",
    "@id": `${site.url}/#website`,
    url: `${site.url}/`,
    name: site.brand,
    inLanguage: site.lang,
    publisher: { "@id": `${site.url}/#org` },
    potentialAction: {
      "@type": "SearchAction",
      target: `${site.url}/buscar?q={search_term_string}`,
      "query-input": "required name=search_term_string",
    },
  },
];

if (match) {
  const countryCode = match.countryCode ?? "FIFA";
  const broadcasters = getBroadcastersForCountry(countryCode);
  const primaryBroadcaster = broadcasters[0];

  graphs.push({
    "@type": "SportsEvent",
    name: `${match.teamA} vs ${match.teamB} — Mundial 2026`,
    sport: "Soccer",
    startDate: match.date,
    url: `${site.url}/${match.slug}`,
    eventStatus: "https://schema.org/EventScheduled",
    eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
    location: {
      "@type": "Place",
      name: match.venue,
      address: { "@type": "PostalAddress", addressLocality: match.city },
    },
    organizer: {
      "@type": "Organization",
      name: "FIFA",
      url: "https://www.fifa.com",
    },
    competitor: [
      { "@type": "SportsTeam", name: match.teamA },
      { "@type": "SportsTeam", name: match.teamB },
    ],
    ...(primaryBroadcaster ? {
      subEvent: [{
        "@type": "BroadcastEvent",
        name: `${match.teamA} vs ${match.teamB} — ${primaryBroadcaster.name}`,
        url: primaryBroadcaster.url,
        isLiveBroadcast: true,
        broadcastOfEvent: {
          "@type": "SportsEvent",
          name: `${match.teamA} vs ${match.teamB}`,
        },
        publishedOn: {
          "@type": "BroadcastService",
          name: primaryBroadcaster.name,
          broadcastDisplayName: primaryBroadcaster.name,
        },
      }],
    } : {}),
  });
}

if (article) {
  graphs.push({
    "@type": "NewsArticle",
    headline: article.title,
    description: article.description,
    datePublished: article.datePublished,
    dateModified: article.datePublished,
    url: article.url,
    author: { "@type": "Organization", name: article.author },
    publisher: { "@id": `${site.url}/#org` },
    inLanguage: site.lang,
  });
}

if (faqs && faqs.length > 0) {
  graphs.push({
    "@type": "FAQPage",
    mainEntity: faqs.map(({ q, a }) => ({
      "@type": "Question",
      name: q,
      acceptedAnswer: { "@type": "Answer", text: a },
    })),
  });
}

if (breadcrumbs && breadcrumbs.length > 0) {
  graphs.push({
    "@type": "BreadcrumbList",
    itemListElement: breadcrumbs.map((bc, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: bc.name,
      ...(bc.item ? { item: bc.item } : {}),
    })),
  });
}

for (const block of extra) {
  graphs.push(block);
}

const jsonld = JSON.stringify({ "@context": "https://schema.org", "@graph": graphs });
---

<script type="application/ld+json" set:html={jsonld} />
