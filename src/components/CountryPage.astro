---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BroadcasterList from "@/components/BroadcasterList.astro";
import { site } from "@/config/site";
import { fixtures, formatDateEs, localTime } from "@/utils/fixtures";

export interface Props {
  countryName: string;
  countryCode: string;
  teamName: string;
  tzLabel: string;
  tzOffset: number;
  slug: string;
  flag: string;
}

const { countryName, countryCode, teamName, tzLabel, tzOffset, slug, flag } = Astro.props;

const teamMatches = fixtures.filter(
  (f) =>
    f.teamA.toLowerCase().includes(teamName.toLowerCase()) ||
    f.teamB.toLowerCase().includes(teamName.toLowerCase())
);

const allMatches = fixtures
  .filter((f) => f.group !== null)
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const breadcrumbs = [
  { name: "Inicio", item: site.url },
  { name: `Mundial 2026 en ${countryName}`, item: `${site.url}/${slug}` },
];

const faqs = [
  {
    q: `¿Dónde ver el Mundial 2026 en ${countryName}?`,
    a: `Podés ver el Mundial 2026 en ${countryName} a través de los canales oficiales que figuran en esta página. Consultá también la página oficial de la FIFA en ${site.fifaWatchUrl}.`,
  },
  {
    q: `¿A qué hora juegan los partidos del Mundial 2026 en ${countryName}?`,
    a: `Los horarios del Mundial 2026 en ${countryName} (${tzLabel}) se muestran en la tabla de esta página. Cada partido tiene su hora local.`,
  },
  {
    q: `¿Qué canal transmite el Mundial 2026 en ${countryName}?`,
    a: `Los canales oficiales que transmiten el Mundial 2026 en ${countryName} se listan en esta página. Para información oficial sobre transmisiones, visitá ${site.fifaWatchUrl}.`,
  },
];
---

<BaseLayout
  title={`Dónde Ver el Mundial 2026 en ${countryName} — Canales Oficiales ${flag}`}
  description={`Guía completa para ver el Mundial 2026 en ${countryName}: canales oficiales, horarios en ${tzLabel}. Todos los partidos del Mundial 2026 con sus horarios locales.`}
  canonical={`${site.url}/${slug}`}
  breadcrumbs={breadcrumbs}
  faqs={faqs}
  promoBannerCountry={countryName}
>
  <h1>Mundial en Vivo en {countryName} {flag} — Dónde Ver el Mundial 2026</h1>
  <p>
    Guía completa para ver el <strong>Mundial 2026 en vivo en {countryName}</strong>. Canales oficiales,
    horarios en {tzLabel} y toda la información del torneo.
  </p>

  <BroadcasterList countryCode={countryCode} countryName={countryName} />

  {teamMatches.length > 0 && (
    <>
      <h2>Partidos de {teamName} — Mundial 2026</h2>
      <table>
        <thead>
          <tr><th>Partido</th><th>Grupo</th><th>Fecha</th><th>Hora ({tzLabel})</th></tr>
        </thead>
        <tbody>
          {teamMatches.map((m) => (
            <tr>
              <td><a href={`/${m.slug}`}>{m.teamA} vs {m.teamB}</a></td>
              <td>{m.group ? `Grupo ${m.group}` : (m.stage ?? "—")}</td>
              <td>{formatDateEs(m.date).split(",")[0]}</td>
              <td>{localTime(m.date, tzOffset)} hs</td>
            </tr>
          ))}
        </tbody>
      </table>
    </>
  )}

  <h2>Todos los Partidos del Mundial 2026 — Horario {countryName}</h2>
  <p style="font-size:.875rem;color:#555;margin-bottom:.5rem">Horarios en {tzLabel}. Hacé clic en cada partido para ver el canal oficial de transmisión.</p>
  <table>
    <thead>
      <tr><th>Partido</th><th>Grupo</th><th>Hora ({tzLabel})</th></tr>
    </thead>
    <tbody>
      {allMatches.slice(0, 24).map((m) => (
        <tr>
          <td><a href={`/${m.slug}`}>{m.teamA} vs {m.teamB}</a></td>
          <td>Grupo {m.group}</td>
          <td>{localTime(m.date, tzOffset)} hs</td>
        </tr>
      ))}
    </tbody>
  </table>
  <p style="font-size:.85rem"><a href="/calendario">Ver calendario completo →</a></p>

  <h2>Preguntas Frecuentes — Mundial 2026 en {countryName}</h2>
  {faqs.map(({ q, a }) => (
    <div style="margin-bottom:1rem">
      <h3>{q}</h3>
      <p>{a}</p>
    </div>
  ))}

  <p style="margin-top:1.5rem">
    ← <a href="/">Volver al inicio</a> ·
    <a href="/calendario">Calendario completo</a> ·
    <a href={site.fifaWatchUrl} target="_blank" rel="noopener">FIFA oficial</a>
  </p>
</BaseLayout>
